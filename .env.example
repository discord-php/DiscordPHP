# Unit tests will use these variables
DISCORD_TOKEN=
TEST_CHANNEL=
TEST_CHANNEL_NAME=

# Optional. Path to a CA certificate bundle (.pem) for TLS verification.
# Only needed on native Windows where PHP cannot read the system cert
# store. Leave blank on Linux/macOS/WSL.
#
# Read at runtime by the Discord constructor and equivalent to passing
# 'cafile' => '...' to new Discord([...]). You must load this .env into
# real environment variables yourself (e.g. with vlucas/phpdotenv) —
# DiscordPHP does not auto-load .env at runtime.
# DISCORDPHP_CAFILE=